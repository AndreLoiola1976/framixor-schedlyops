# SchedlyOps — runtime configuration
# In Lovable these values must be configured through Workspace Settings → Build Secrets.
# Do not commit real credentials to the repo.

# Supabase is the default development path.
# Mock mode exists only for isolated UI development and testing.
VITE_DATA_SOURCE=supabase

# Required when VITE_DATA_SOURCE=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Pilot tenant slug — compared against operator_current_tenant().slug as a guard.
VITE_SCHEDLYOPS_TENANT_SLUG=demo-barber
