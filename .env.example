# SchedlyOps — runtime configuration
# Set these in Workspace Settings → Build Secrets (do not commit real values).

# Data source: "mock" uses local fixtures; "supabase" calls the Framixor backend.
VITE_DATA_SOURCE=mock

# Required when VITE_DATA_SOURCE=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Pilot tenant slug — compared against operator_current_tenant().slug as a guard.
VITE_SCHEDLYOPS_TENANT_SLUG=demo-barber
